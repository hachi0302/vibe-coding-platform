{
  "name": "vibe-coding-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tauri": "tauri",
    "prepare": "husky",
    "release": "bumpp --git-check package.json package-lock.json src-tauri/tauri.conf.json src-tauri/Cargo.toml --commit \"release: v%s\" --tag \"v%s\" --push",
    "release:patch": "bumpp --release patch --yes --git-check package.json package-lock.json src-tauri/tauri.conf.json src-tauri/Cargo.toml --commit \"release: v%s\" --tag \"v%s\" --push",
    "release:minor": "bumpp --release minor --yes --git-check package.json package-lock.json src-tauri/tauri.conf.json src-tauri/Cargo.toml --commit \"release: v%s\" --tag \"v%s\" --push",
    "release:major": "bumpp --release major --yes --git-check package.json package-lock.json src-tauri/tauri.conf.json src-tauri/Cargo.toml --commit \"release: v%s\" --tag \"v%s\" --push"
  },
  "changelogithub": {
    "types": {
      "feat": {
        "title": "🚀 Features"
      },
      "Feat": {
        "title": "🚀 Features"
      },
      "fix": {
        "title": "🐞 Bug Fixes"
      },
      "Fix": {
        "title": "🐞 Bug Fixes"
      },
      "perf": {
        "title": "🏎 Performance"
      },
      "refactor": {
        "title": "💅 Refactors"
      },
      "doc": {
        "title": "📖 Documentation"
      },
      "Doc": {
        "title": "📖 Documentation"
      },
      "Docs": {
        "title": "📖 Documentation"
      },
      "docs": {
        "title": "📖 Documentation"
      }
    },
    "contributors": true
  },
  "dependencies": {
    "@antv/g2": "^5.4.8",
    "@tanstack/vue-virtual": "^3.13.31",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "mermaid": "^11.15.0",
    "shiki": "^4.2.0",
    "vue": "^3.5.34",
    "vue-easy-lightbox": "^1.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@iconify-json/arcticons": "^1.2.53",
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/material-icon-theme": "^1.2.65",
    "@iconify-json/mingcute": "^1.2.7",
    "@iconify-json/quill": "^1.2.4",
    "@iconify/utils": "^3.1.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "bumpp": "^11.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.14",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  }
}
