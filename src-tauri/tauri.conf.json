{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Coding Platform",
  "version": "0.1.0",
  "identifier": "com.wangaixin.vibecodingplatform",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "features": []
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1360,
        "height": 850,
        "minWidth": 880,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDQjAyNzg1NDkyREM2QjcKUldTM3hpMUpoU2V3VFBJMmVOYnl4S1BwMUIxNWFIbEZWQTBqODZrTnRtOVh4NXl1SDgxd1pORzQK",
      "endpoints": [
        "https://github.com/wangaixin0302-hachi/vibe-coding-platform/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
